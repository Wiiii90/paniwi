# Local sync source mode:
# - mock: stable local demo data
# - auto: api-football -> wikipedia -> mock
# - wikipedia: MediaWiki goalscorers prototype
# - api-football: API-Football fixture events
SYNC_SOURCE=mock

# Wikipedia prototype settings
WIKIPEDIA_API_ENDPOINT=https://en.wikipedia.org/w/api.php
WIKIPEDIA_GOALS_PAGE=2026 FIFA World Cup
WIKIPEDIA_TIMEOUT_MS=10000

# API-Football settings
# Never commit a real key in .env. Use GitHub Secrets for Actions.
API_FOOTBALL_KEY=
API_FOOTBALL_FIXTURE_IDS=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_TIMEOUT_MS=10000

# Optional GitHub Pages override. Usually inferred from GITHUB_REPOSITORY in Actions.
GITHUB_PAGES_BASE=
